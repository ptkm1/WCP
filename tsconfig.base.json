{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@wcp/domain": ["packages/domain/src/index.ts"],
      "@wcp/application": ["packages/application/src/index.ts"],
      "@wcp/db": ["packages/db/src/index.ts"],
      "@wcp/integrations-git": ["packages/integrations-git/src/index.ts"],
      "@wcp/integrations-pm": ["packages/integrations-pm/src/index.ts"],
      "@wcp/ui": ["packages/ui/src/index.ts"],
      "@wcp/shared": ["packages/shared/src/index.ts"]
    }
  }
}
