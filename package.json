{
  "name": "work-context-platform",
  "private": true,
  "packageManager": "pnpm@9.12.2",
  "pnpm": {
    "overrides": {
      "react-native-safe-area-context": "4.10.5",
      "react-native-screens": "3.31.1"
    }
  },
  "scripts": {
    "dev:desktop": "pnpm --filter @wcp/desktop dev",
    "dev:desktop:tauri": "pnpm --filter @wcp/desktop tauri:dev",
    "dev:mobile": "pnpm --filter @wcp/mobile dev",
    "setup:desktop": "pnpm db:migrate && pnpm db:seed",
    "start:desktop": "pnpm setup:desktop && pnpm dev:desktop:tauri",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @wcp/db db:generate",
    "db:migrate": "pnpm --filter @wcp/db db:migrate",
    "db:seed": "pnpm --filter @wcp/db db:seed"
  }
}
